-    body: formData.toString()
-  });
-
-  const data = await response.json();
-
-  if (!response.ok) {
-    console.error('[WhatsApp] Twilio error response:', JSON.stringify(data));
-    throw new Error(`Twilio ${response.status}: ${data.message || data.code || JSON.stringify(data)}`);
-  }
-
-  return data;
